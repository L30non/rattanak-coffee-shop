{"nodes": [{"id": "khqr_sdk_document", "label": "KHQR SDK Documentation v2.7 (NBC)", "file_type": "document", "source_file": "KHQR SDK Document.pdf", "source_location": "pages 1-4", "source_url": null, "captured_at": null, "author": "National Bank of Cambodia", "contributor": null}, {"id": "khqr_sdk_document_khqr", "label": "KHQR Code Specification", "file_type": "rationale", "source_file": "KHQR SDK Document.pdf", "source_location": "page 4 (Introduction)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Standardizing the QR code specification promotes wider mobile retail payments in Cambodia, gives a consistent merchant/consumer experience, and enables interoperability across schemes, e-wallets, and banks: a single QR receives transactions from any payment provider through Bakong, encouraging small merchants to adopt it. Created for retail/remittance in Cambodia and cross-border."}, {"id": "khqr_sdk_document_bakong", "label": "Bakong Payment Platform", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "page 4", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "khqr_sdk_document_national_bank_of_cambodia", "label": "National Bank of Cambodia (NBC)", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "page 4 (Purpose)", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "khqr_sdk_document_prakas_khqr_specification", "label": "Prakas KHQR Code Specification in Cambodia", "file_type": "document", "source_file": "KHQR SDK Document.pdf", "source_location": "page 4 (Overview)", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "khqr_sdk_document_bakongkhqr", "label": "BakongKHQR SDK (iOS, Java, C#, Javascript)", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "pages 8-16 (Features, Requirement, Installation)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Distributed for four platforms (CocoaPods, Maven/Gradle, NuGet, NPM) so any bank or third-party app in the Bakong ecosystem can generate and process KHQR codes with identical semantics; package namespace changed from .org to .gov in v2.5."}, {"id": "khqr_sdk_document_generate_khqr", "label": "Generate KHQR (Individual and Merchant)", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "pages 14-19 (Request Parameter, Usage)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Produces an EMV QR string plus an md5 hash; a timestamp is embedded in the QR string so each generated code is unique. Individual type requires BakongAccountID and MerchantName; Merchant type additionally requires MerchantID and AcquiringBank."}, {"id": "khqr_sdk_document_verify_khqr", "label": "Verify KHQR", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "pages 15, 19-20", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Returns CRC validation (valid/invalid) for a KHQR string; v2.3 fixed the verify function to treat QRs containing optional non-standard subtags as valid."}, {"id": "khqr_sdk_document_decode_khqr", "label": "Decode KHQR", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "pages 16, 21-22", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Extracts all EMV tag fields (bakongAccountID, merchant info, amount, currency, timestamp, CRC, UPI/alternate-language tags) from a KHQR string without validating required fields (since v1.7)."}, {"id": "khqr_sdk_document_generate_deeplink", "label": "Generate KHQR Deeplink", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "pages 16, 22-23, 38", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Converts a KHQR string into a short link for app-to-app payment routing; the deeplink API URL is provided by the NBC team, and generated short links differ on every call and depend on which API URL is used."}, {"id": "khqr_sdk_document_individualinfo", "label": "IndividualInfo Request Structure", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "page 14", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "khqr_sdk_document_merchantinfo", "label": "MerchantInfo Request Structure", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "page 15", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "khqr_sdk_document_sourceinfo", "label": "SourceInfo Deeplink Structure (appIconUrl, appName, appDeepLinkCallBack)", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "page 16", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "khqr_sdk_document_standard_response", "label": "KHQR Standard Response Format", "file_type": "concept", "source_file": "KHQR SDK Document.pdf", "source_location": "pages 39-41", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uniform envelope across all SDK functions and platforms: status {code 0=success/1=failed, errorCode 1-43 with defined messages, message} plus function-specific data; consistent error codes let integrators handle validation failures identically in iOS, Java, C#, and Javascript."}, {"id": "khqr_sdk_document_md5_hash", "label": "MD5 Hash for Transaction Status Verification", "file_type": "rationale", "source_file": "KHQR SDK Document.pdf", "source_location": "page 41 (Response Key definitions)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The md5 returned alongside the generated QR is the hash value of the Bakong KHQR used to verify transaction status against the Bakong Open API \u2014 the mechanism a merchant backend polls to confirm a customer actually paid."}], "edges": [{"source": "khqr_sdk_document", "target": "khqr_sdk_document_bakongkhqr", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "KHQR SDK Document.pdf", "source_location": "pages 8-16", "weight": 1.0}, {"source": "khqr_sdk_document", "target": "khqr_sdk_document_prakas_khqr_specification", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "KHQR SDK Document.pdf", "source_location": "page 4: 'please refer to Prakas KHQR Code Specification in Cambodia'", "weight": 1.0}, {"source": "khqr_sdk_document_bakongkhqr", "target": "khqr_sdk_document_generate_khqr", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "KHQR SDK Document.pdf", "source_location": "page 8 (Features), pages 16-19", "weight": 1.0}, {"source": "khqr_sdk_document_bakongkhqr", "target": "khqr_sdk_document_verify_khqr", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "KHQR SDK Document.pdf", "source_location": "page 8 (Features), pages 19-20", "weight": 1.0}, {"source": "khqr_sdk_document_bakongkhqr", "target": "khqr_sdk_document_decode_khqr", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "KHQR SDK Document.pdf", "source_location": "page 8 (Features), pages 21-22", "weight": 1.0}, {"source": "khqr_sdk_document_bakongkhqr", "target": "khqr_sdk_document_generate_deeplink", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "KHQR SDK Document.pdf", "source_location": "page 8 (Features), pages 22-23", "weight": 1.0}, {"source": "khqr_sdk_document_generate_khqr", "target": "khqr_sdk_document_individualinfo", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "