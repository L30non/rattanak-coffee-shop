qr", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "KHQR SDK Document.pdf", "source_location": "pages 4-8: SDK implements the KHQR specification", "weight": 1.0}], "hyperedges": [{"id": "khqr_sdk_core_api", "label": "KHQR SDK Core API Surface", "nodes": ["khqr_sdk_document_bakongkhqr", "khqr_sdk_document_generate_khqr", "khqr_sdk_document_verify_khqr", "khqr_sdk_document_decode_khqr", "khqr_sdk_document_generate_deeplink"], "relation": "form", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "KHQR SDK Document.pdf"}]}